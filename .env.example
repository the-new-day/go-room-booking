# App config
LOG_LEVEL=debug

# PostgresSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=meeting_booking
POSTGRES_SSLMODE=disable
POSTGRES_MAX_POOL_SIZE=20

# HTTP server
HTTP_PORT=8080
HTTP_SERVER_TIMEOUT=4s
HTTP_SERVER_IDLE_TIMEOUT=20s

# JWT
JWT_SIGN_KEY=secret_key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
